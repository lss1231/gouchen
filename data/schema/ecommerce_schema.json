{
  "tables": [
    {
      "table_name": "dim_date",
      "table_cn_name": "日期维度表",
      "description": "日期维度表，包含日期相关的各种维度信息，用于时间序列分析",
      "datasource": "mysql",
      "fields": [
        {
          "field_name": "date_key",
          "field_cn_name": "日期键",
          "data_type": "INT",
          "description": "日期主键，格式YYYYMMDD"
        },
        {
          "field_name": "date",
          "field_cn_name": "日期",
          "data_type": "DATE",
          "description": "标准日期格式"
        },
        {
          "field_name": "year",
          "field_cn_name": "年份",
          "data_type": "INT",
          "description": "年份，如2024"
        },
        {
          "field_name": "month",
          "field_cn_name": "月份",
          "data_type": "INT",
          "description": "月份，1-12"
        },
        {
          "field_name": "day",
          "field_cn_name": "日",
          "data_type": "INT",
          "description": "日期，1-31"
        },
        {
          "field_name": "quarter",
          "field_cn_name": "季度",
          "data_type": "INT",
          "description": "季度，1-4"
        },
        {
          "field_name": "week_of_year",
          "field_cn_name": "周次",
          "data_type": "INT",
          "description": "一年中的第几周"
        },
        {
          "field_name": "is_weekend",
          "field_cn_name": "是否周末",
          "data_type": "BOOLEAN",
          "description": "是否为周末"
        }
      ]
    },
    {
      "table_name": "dim_region",
      "table_cn_name": "地区维度表",
      "description": "地区维度表，包含省市区等地理层级信息",
      "datasource": "mysql",
      "fields": [
        {
          "field_name": "region_code",
          "field_cn_name": "地区编码",
          "data_type": "VARCHAR(20)",
          "description": "地区唯一编码"
        },
        {
          "field_name": "region_name",
          "field_cn_name": "地区名称",
          "data_type": "VARCHAR(100)",
          "description": "地区名称，如华东、华南"
        },
        {
          "field_name": "province",
          "field_cn_name": "省份",
          "data_type": "VARCHAR(50)",
          "description": "省份名称"
        },
        {
          "field_name": "city",
          "field_cn_name": "城市",
          "data_type": "VARCHAR(50)",
          "description": "城市名称"
        },
        {
          "field_name": "region_level",
          "field_cn_name": "地区层级",
          "data_type": "INT",
          "description": "地区层级，1-大区，2-省，3-市"
        },
        {
          "field_name": "parent_code",
          "field_cn_name": "父级编码",
          "data_type": "VARCHAR(20)",
          "description": "父级地区编码"
        }
      ]
    },
    {
      "table_name": "dim_category",
      "table_cn_name": "商品类目表",
      "description": "商品类目维度表，包含商品分类层级关系",
      "datasource": "mysql",
      "fields": [
        {
          "field_name": "category_id",
          "field_cn_name": "类目ID",
          "data_type": "INT",
          "description": "类目唯一标识"
        },
        {
          "field_name": "category_name",
          "field_cn_name": "类目名称",
          "data_type": "VARCHAR(100)",
          "description": "类目名称，如电子产品、服装"
        },
        {
          "field_name": "parent_id",
          "field_cn_name": "父类目ID",
          "data_type": "INT",
          "description": "父级类目ID，顶级为0"
        },
        {
          "field_name": "category_level",
          "field_cn_name": "类目层级",
          "data_type": "INT",
          "description": "类目层级，1-一级类目，2-二级类目"
        },
        {
          "field_name": "category_path",
          "field_cn_name": "类目路径",
          "data_type": "VARCHAR(500)",
          "description": "类目完整路径"
        }
      ]
    },
    {
      "table_name": "dim_product",
      "table_cn_name": "商品维度表",
      "description": "商品维度表，包含商品基本信息",
      "datasource": "mysql",
      "fields": [
        {
          "field_name": "product_id",
          "field_cn_name": "商品ID",
          "data_type": "INT",
          "description": "商品唯一标识"
        },
        {
          "field_name": "product_name",
          "field_cn_name": "商品名称",
          "data_type": "VARCHAR(200)",
          "description": "商品名称"
        },
        {
          "field_name": "category_id",
          "field_cn_name": "类目ID",
          "data_type": "INT",
          "description": "所属类目ID"
        },
        {
          "field_name": "price",
          "field_cn_name": "商品价格",
          "data_type": "DECIMAL(10,2)",
          "description": "商品标准售价"
        },
        {
          "field_name": "cost_price",
          "field_cn_name": "成本价",
          "data_type": "DECIMAL(10,2)",
          "description": "商品成本价格"
        },
        {
          "field_name": "brand",
          "field_cn_name": "品牌",
          "data_type": "VARCHAR(100)",
          "description": "商品品牌"
        },
        {
          "field_name": "status",
          "field_cn_name": "状态",
          "data_type": "TINYINT",
          "description": "商品状态：0-下架，1-上架"
        }
      ]
    },
    {
      "table_name": "fact_order",
      "table_cn_name": "订单事实表",
      "description": "订单事实表，存储订单级别的交易数据",
      "datasource": "mysql",
      "fields": [
        {
          "field_name": "order_id",
          "field_cn_name": "订单ID",
          "data_type": "BIGINT",
          "description": "订单唯一标识"
        },
        {
          "field_name": "order_date",
          "field_cn_name": "订单日期",
          "data_type": "DATE",
          "description": "订单创建日期"
        },
        {
          "field_name": "region_code",
          "field_cn_name": "地区编码",
          "data_type": "VARCHAR(20)",
          "description": "订单所属地区编码"
        },
        {
          "field_name": "order_amount",
          "field_cn_name": "订单金额",
          "data_type": "DECIMAL(12,2)",
          "description": "订单总金额"
        },
        {
          "field_name": "paid_amount",
          "field_cn_name": "实付金额",
          "data_type": "DECIMAL(12,2)",
          "description": "用户实际支付金额"
        },
        {
          "field_name": "discount_amount",
          "field_cn_name": "优惠金额",
          "data_type": "DECIMAL(12,2)",
          "description": "订单优惠金额"
        },
        {
          "field_name": "order_status",
          "field_cn_name": "订单状态",
          "data_type": "TINYINT",
          "description": "订单状态：0-待支付，1-已支付，2-已发货，3-已完成，4-已取消"
        },
        {
          "field_name": "user_id",
          "field_cn_name": "用户ID",
          "data_type": "BIGINT",
          "description": "下单用户ID"
        }
      ]
    },
    {
      "table_name": "fact_order_item",
      "table_cn_name": "订单明细表",
      "description": "订单明细表，存储订单商品级别的详细数据",
      "datasource": "mysql",
      "fields": [
        {
          "field_name": "item_id",
          "field_cn_name": "明细ID",
          "data_type": "BIGINT",
          "description": "订单明细唯一标识"
        },
        {
          "field_name": "order_id",
          "field_cn_name": "订单ID",
          "data_type": "BIGINT",
          "description": "关联订单ID"
        },
        {
          "field_name": "product_id",
          "field_cn_name": "商品ID",
          "data_type": "INT",
          "description": "商品ID"
        },
        {
          "field_name": "quantity",
          "field_cn_name": "数量",
          "data_type": "INT",
          "description": "购买数量"
        },
        {
          "field_name": "item_amount",
          "field_cn_name": "明细金额",
          "data_type": "DECIMAL(12,2)",
          "description": "该商品明细金额"
        },
        {
          "field_name": "item_price",
          "field_cn_name": "商品单价",
          "data_type": "DECIMAL(10,2)",
          "description": "商品成交单价"
        }
      ]
    }
  ]
}