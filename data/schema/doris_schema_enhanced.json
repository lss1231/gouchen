{
  "tables": [
    {
      "table_name": "dim_date",
      "table_cn_name": "日期维度表",
      "description": "数据仓库日期维度表，提供标准日期属性支持时间序列分析。包含公历日期、农历标记、节假日标识、财年会话等。用于关联事实表进行按日/周/月/季/年统计分析，支持同比环比计算。",
      "datasource": "doris",
      "layer": "DIM",
      "keywords": ["日期", "时间", "日历", "节假日", "星期", "季度", "年月", "date", "time", "calendar"],
      "fields": [
        {"field_name": "date_key", "field_cn_name": "日期键", "data_type": "INT", "description": "日期主键，YYYYMMDD格式，如20240101表示2024年1月1日"},
        {"field_name": "date_str", "field_cn_name": "日期字符串", "data_type": "VARCHAR(10)", "description": "标准日期格式YYYY-MM-DD字符串"},
        {"field_name": "day_of_week", "field_cn_name": "星期几", "data_type": "TINYINT", "description": "星期几，1=周一，7=周日"},
        {"field_name": "day_name", "field_cn_name": "星期名称", "data_type": "VARCHAR(10)", "description": "星期几名称，如'星期一'"},
        {"field_name": "month_name", "field_cn_name": "月份名称", "data_type": "VARCHAR(10)", "description": "月份名称，如'一月'"},
        {"field_name": "holiday_name", "field_cn_name": "节假日名称", "data_type": "VARCHAR(50)", "description": "节假日名称，如'春节'、'国庆'，非节假日为空"},
        {"field_name": "year", "field_cn_name": "年份", "data_type": "SMALLINT", "description": "四位年份数字，如2024"},
        {"field_name": "month", "field_cn_name": "月份", "data_type": "TINYINT", "description": "月份数字1-12，1表示一月"},
        {"field_name": "day", "field_cn_name": "日期", "data_type": "TINYINT", "description": "日期数字1-31"},
        {"field_name": "quarter", "field_cn_name": "季度", "data_type": "TINYINT", "description": "财年季度1-4，Q1(1-3月)、Q2(4-6月)、Q3(7-9月)、Q4(10-12月)"},
        {"field_name": "week_of_year", "field_cn_name": "年内周数", "data_type": "TINYINT", "description": "该日期是年内第几周，1-53"},
        {"field_name": "is_weekend", "field_cn_name": "是否周末", "data_type": "BOOLEAN", "description": "是否周末：true表示周六或周日，false表示工作日"},
        {"field_name": "is_holiday", "field_cn_name": "是否节假日", "data_type": "BOOLEAN", "description": "是否法定节假日：true表示国定假日（春节、国庆等），false表示普通日期"}
      ]
    },
    {
      "table_name": "dim_region",
      "table_cn_name": "地区维度表",
      "description": "中国行政区划维度表，存储省市区三级地理信息，包括地域标签（华东/华南等）、城市等级（一线/二线/三线）。用于订单地域分析、用户地域分布、区域销售统计、物流规划。",
      "datasource": "doris",
      "layer": "DIM",
      "keywords": ["地区", "省份", "城市", "地域", "行政区划", "地理", "region", "province", "city", "location"],
      "fields": [
        {"field_name": "region_id", "field_cn_name": "地区ID", "data_type": "INT", "description": "地区唯一标识"},
        {"field_name": "region_name", "field_cn_name": "地区名称", "data_type": "VARCHAR(50)", "description": "地区名称"},
        {"field_name": "region_level", "field_cn_name": "地区级别", "data_type": "TINYINT", "description": "地区级别：1省，2市，3区"},
        {"field_name": "parent_id", "field_cn_name": "父级ID", "data_type": "INT", "description": "上级地区ID，省级的parent_id为0"},
        {"field_name": "region_path", "field_cn_name": "地区路径", "data_type": "VARCHAR(200)", "description": "地区完整路径，如'1/110000/110101'"},
        {"field_name": "region_code", "field_cn_name": "地区编码", "data_type": "VARCHAR(20)", "description": "国标行政区划代码，如'110000'表示北京市"}
      ]
    },
    {
      "table_name": "dim_product",
      "table_cn_name": "商品维度表",
      "description": "商品信息维度表，从ODS层清洗加工而来，包含完整商品属性、类目路径、品牌信息、价格成本等。用于关联订单明细进行商品分析、类目分析、品牌分析、利润计算。",
      "datasource": "doris",
      "layer": "DIM",
      "keywords": ["商品维度", "SKU", "SPU", "类目", "品牌", "product", "SKU", "category"],
      "fields": [
        {"field_name": "product_id", "field_cn_name": "商品ID", "data_type": "BIGINT", "description": "商品唯一标识"},
        {"field_name": "product_name", "field_cn_name": "商品名称", "data_type": "VARCHAR(200)", "description": "商品完整名称"},
        {"field_name": "category_id", "field_cn_name": "类目ID", "data_type": "INT", "description": "所属三级类目ID"},
        {"field_name": "category_name", "field_cn_name": "类目名称", "data_type": "VARCHAR(100)", "description": "类目完整路径，如'家电/电视/4K电视'"},
        {"field_name": "brand_id", "field_cn_name": "品牌ID", "data_type": "INT", "description": "品牌唯一标识"},
        {"field_name": "brand_name", "field_cn_name": "品牌名称", "data_type": "VARCHAR(50)", "description": "品牌中文名，如'苹果'、'华为'"},
        {"field_name": "price", "field_cn_name": "销售价", "data_type": "DECIMAL(12,2)", "description": "商品当前售价"},
        {"field_name": "cost", "field_cn_name": "成本价", "data_type": "DECIMAL(12,2)", "description": "商品成本，用于计算毛利"},
        {"field_name": "profit_rate", "field_cn_name": "毛利率", "data_type": "DECIMAL(5,4)", "description": "毛利率 = (售价-成本)/售价，如0.25表示25%毛利"},
        {"field_name": "status", "field_cn_name": "商品状态", "data_type": "TINYINT", "description": "0下架，1上架"},
        {"field_name": "create_date", "field_cn_name": "创建日期", "data_type": "DATE", "description": "商品首次上架日期"},
        {"field_name": "update_date", "field_cn_name": "更新日期", "data_type": "DATE", "description": "商品信息最后更新日期"}
      ]
    },
    {
      "table_name": "dwd_order_detail",
      "table_cn_name": "订单明细宽表",
      "description": "订单事实明细宽表，融合订单、商品、用户、地区等维度信息。每条记录代表一个订单中的一个商品行（如订单买了3件商品则有3条记录）。包含完整订单属性、商品快照、用户属性、地区信息、利润计算字段。是销售分析、利润分析、用户行为分析的核心事实表。",
      "datasource": "doris",
      "layer": "DWD",
      "keywords": ["订单明细", "交易明细", "订单宽表", "销售明细", "order detail", "fact table"],
      "fields": [
        {"field_name": "order_id", "field_cn_name": "订单ID", "data_type": "BIGINT", "description": "订单唯一标识"},
        {"field_name": "order_item_id", "field_cn_name": "明细ID", "data_type": "BIGINT", "description": "订单明细行唯一标识"},
        {"field_name": "user_id", "field_cn_name": "买家用户ID", "data_type": "BIGINT", "description": "下单用户ID"},
        {"field_name": "product_id", "field_cn_name": "商品ID", "data_type": "BIGINT", "description": "购买的商品ID"},
        {"field_name": "category_id", "field_cn_name": "类目ID", "data_type": "INT", "description": "商品所属类目ID"},
        {"field_name": "brand_id", "field_cn_name": "品牌ID", "data_type": "INT", "description": "商品品牌ID"},
        {"field_name": "quantity", "field_cn_name": "购买数量", "data_type": "INT", "description": "该商品购买件数"},
        {"field_name": "unit_price", "field_cn_name": "商品单价", "data_type": "DECIMAL(12,2)", "description": "下单时商品单价"},
        {"field_name": "discount_amount", "field_cn_name": "优惠金额", "data_type": "DECIMAL(12,2)", "description": "该商品行优惠金额"},
        {"field_name": "pay_amount", "field_cn_name": "实付金额", "data_type": "DECIMAL(12,2)", "description": "该商品行实际支付金额（分摊优惠后）"},
        {"field_name": "unit_cost", "field_cn_name": "单位成本", "data_type": "DECIMAL(12,2)", "description": "商品单位成本价"},
        {"field_name": "profit", "field_cn_name": "毛利", "data_type": "DECIMAL(12,2)", "description": "该商品行毛利 = (单价-成本) × 数量"},
        {"field_name": "order_status", "field_cn_name": "订单状态", "data_type": "TINYINT", "description": "1待支付，2已支付，3已发货，4已完成，5已取消"},
        {"field_name": "pay_type", "field_cn_name": "支付方式", "data_type": "TINYINT", "description": "1支付宝，2微信，3银行卡，4余额"},
        {"field_name": "province_id", "field_cn_name": "省份ID", "data_type": "INT", "description": "收货省份ID"},
        {"field_name": "city_id", "field_cn_name": "城市ID", "data_type": "INT", "description": "收货城市ID"},
        {"field_name": "order_date", "field_cn_name": "订单日期", "data_type": "DATE", "description": "订单创建日期，格式YYYY-MM-DD"},
        {"field_name": "order_month", "field_cn_name": "订单月份", "data_type": "INT", "description": "订单月份，格式YYYYMM，如202401"},
        {"field_name": "pay_time", "field_cn_name": "支付时间", "data_type": "DATETIME", "description": "用户支付时间"},
        {"field_name": "create_time", "field_cn_name": "创建时间", "data_type": "DATETIME", "description": "订单创建时间"}
      ]
    },
    {
      "table_name": "dws_sales_daily",
      "table_cn_name": "日销售汇总表",
      "description": "日级销售汇总表，按日期、省份、类目三个维度汇总销售指标。包含订单数、用户数、GMV、实付金额、优惠金额、退货指标等核心销售KPI。用于日报生成、趋势分析、同比环比计算、地域/类目销售分析。",
      "datasource": "doris",
      "layer": "DWS",
      "keywords": ["日销售", "日报", "每日统计", "日汇总", "daily sales", "日GMV", "日订单"],
      "fields": [
        {"field_name": "stat_date", "field_cn_name": "统计日期", "data_type": "DATE", "description": "汇总统计日期"},
        {"field_name": "province_id", "field_cn_name": "省份ID", "data_type": "INT", "description": "收货省份ID"},
        {"field_name": "category_id", "field_cn_name": "类目ID", "data_type": "INT", "description": "商品类目ID"},
        {"field_name": "order_count", "field_cn_name": "订单数", "data_type": "BIGINT", "description": "当日订单数量（去重）"},
        {"field_name": "order_user_count", "field_cn_name": "下单用户数", "data_type": "BIGINT", "description": "当日下单的去重用户数"},
        {"field_name": "product_count", "field_cn_name": "商品种数", "data_type": "BIGINT", "description": "当日销售的商品SKU种类数"},
        {"field_name": "gmv", "field_cn_name": "GMV", "data_type": "DECIMAL(18,2)", "description": "商品交易总额（订单金额合计，未扣除优惠）"},
        {"field_name": "discount_amount", "field_cn_name": "优惠金额", "data_type": "DECIMAL(18,2)", "description": "当日优惠总金额"},
        {"field_name": "actual_amount", "field_cn_name": "实付金额", "data_type": "DECIMAL(18,2)", "description": "用户实际支付金额合计"},
        {"field_name": "cost_amount", "field_cn_name": "成本金额", "data_type": "DECIMAL(18,2)", "description": "销售商品成本合计"},
        {"field_name": "profit_amount", "field_cn_name": "毛利金额", "data_type": "DECIMAL(18,2)", "description": "当日毛利 = 实付金额 - 成本金额"}
      ]
    },
    {
      "table_name": "dws_sales_monthly",
      "table_cn_name": "月销售汇总表",
      "description": "月级销售汇总表，按月份、省份、类目汇总销售指标。包含月度GMV、订单数、用户数、成本、利润等。用于月报生成、月度经营分析、趋势对比、年度规划。",
      "datasource": "doris",
      "layer": "DWS",
      "keywords": ["月销售", "月报", "每月统计", "月汇总", "monthly sales", "月度GMV", "月度订单"],
      "fields": [
        {"field_name": "stat_month", "field_cn_name": "统计月份", "data_type": "INT", "description": "统计月份，格式YYYYMM"},
        {"field_name": "province_id", "field_cn_name": "省份ID", "data_type": "INT", "description": "收货省份ID"},
        {"field_name": "category_id", "field_cn_name": "类目ID", "data_type": "INT", "description": "商品类目ID"},
        {"field_name": "order_count", "field_cn_name": "订单数", "data_type": "BIGINT", "description": "当月订单数量"},
        {"field_name": "order_user_count", "field_cn_name": "下单用户数", "data_type": "BIGINT", "description": "当月下单的去重用户数"},
        {"field_name": "product_count", "field_cn_name": "商品种数", "data_type": "BIGINT", "description": "当月销售的商品SKU种类数"},
        {"field_name": "gmv", "field_cn_name": "GMV", "data_type": "DECIMAL(18,2)", "description": "当月商品交易总额"},
        {"field_name": "discount_amount", "field_cn_name": "优惠金额", "data_type": "DECIMAL(18,2)", "description": "当月优惠总金额"},
        {"field_name": "actual_amount", "field_cn_name": "实付金额", "data_type": "DECIMAL(18,2)", "description": "当月用户实际支付金额"},
        {"field_name": "cost_amount", "field_cn_name": "成本金额", "data_type": "DECIMAL(18,2)", "description": "当月销售商品成本合计"},
        {"field_name": "profit_amount", "field_cn_name": "毛利金额", "data_type": "DECIMAL(18,2)", "description": "当月毛利 = 实付金额 - 成本金额"}
      ]
    },
    {
      "table_name": "dws_user_stats",
      "table_cn_name": "用户统计表",
      "description": "日级用户指标汇总表，包含活跃用户、付费用户、订单数等核心用户运营指标。用于用户增长分析、活跃度监控、用户运营效果评估。",
      "datasource": "doris",
      "layer": "DWS",
      "keywords": ["用户统计", "用户增长", "活跃用户", "新增用户", "user stats", "日活"],
      "fields": [
        {"field_name": "stat_date", "field_cn_name": "统计日期", "data_type": "DATE", "description": "统计日期"},
        {"field_name": "new_users", "field_cn_name": "新增用户", "data_type": "BIGINT", "description": "当日新注册用户数"},
        {"field_name": "active_users", "field_cn_name": "活跃用户", "data_type": "BIGINT", "description": "当日活跃用户数"},
        {"field_name": "paying_users", "field_cn_name": "付费用户数", "data_type": "BIGINT", "description": "当日有支付行为的去重用户数"},
        {"field_name": "gmv_per_user", "field_cn_name": "人均GMV", "data_type": "DECIMAL(12,2)", "description": "人均GMV = 当日GMV / 付费用户数"},
        {"field_name": "orders_per_user", "field_cn_name": "人均订单数", "data_type": "DECIMAL(5,2)", "description": "人均订单数 = 当日订单数 / 付费用户数"},
        {"field_name": "total_users", "field_cn_name": "累计用户", "data_type": "BIGINT", "description": "截至当日的累计注册用户数"}
      ]
    },
    {
      "table_name": "ads_sales_kpi",
      "table_cn_name": "销售KPI指标表",
      "description": "应用层销售核心指标表，面向业务人员的日报/月报数据源。包含GMV、订单数、客单价、转化率等关键销售指标及环比、同比数据。用于数据看板、经营日报、目标达成追踪。",
      "datasource": "doris",
      "layer": "ADS",
      "keywords": ["销售KPI", "核心指标", "GMV", "转化率", "客单价", "sales KPI", "经营指标", "业绩"],
      "fields": [
        {"field_name": "stat_date", "field_cn_name": "统计日期", "data_type": "DATE", "description": "KPI统计日期"},
        {"field_name": "kpi_name", "field_cn_name": "指标名称", "data_type": "VARCHAR(50)", "description": "指标名称：GMV、订单数、用户数、客单价、转化率、实付金额、利润"},
        {"field_name": "kpi_value", "field_cn_name": "指标值", "data_type": "DECIMAL(18,2)", "description": "指标数值"},
        {"field_name": "kpi_unit", "field_cn_name": "单位", "data_type": "VARCHAR(20)", "description": "单位：元、单、人、%"},
        {"field_name": "mom_growth", "field_cn_name": "环比", "data_type": "DECIMAL(5,2)", "description": "环比变化率，与上一周期对比"},
        {"field_name": "yoy_growth", "field_cn_name": "同比", "data_type": "DECIMAL(5,2)", "description": "同比变化率，与去年同期对比"}
      ]
    },
    {
      "table_name": "ads_user_retention",
      "table_cn_name": "用户留存分析表",
      "description": "应用层用户留存分析表，记录不同注册日期的用户群体在后续日期的留存情况。支持计算次日留存、3日留存、7日留存、30日留存。用于留存趋势分析、 cohort分析、用户质量评估。",
      "datasource": "doris",
      "layer": "ADS",
      "keywords": ["留存率", "用户留存", "次日留存", "7日留存", "30日留存", "retention", "cohort分析"],
      "fields": [
        {"field_name": "stat_date", "field_cn_name": "统计日期", "data_type": "DATE", "description": "留存统计日期"},
        {"field_name": "register_date", "field_cn_name": "注册日期", "data_type": "DATE", "description": "用户注册日期（cohort分组依据）"},
        {"field_name": "retention_day", "field_cn_name": "留存天数", "data_type": "INT", "description": "留存天数：1表示次日，3表示3日，7表示7日，30表示30日"},
        {"field_name": "new_user_count", "field_cn_name": "新增用户数", "data_type": "BIGINT", "description": "注册日期当天的新增用户数"},
        {"field_name": "retained_user_count", "field_cn_name": "留存用户数", "data_type": "BIGINT", "description": "注册日期 cohort 中，在统计日期仍活跃的用户数"},
        {"field_name": "retention_rate", "field_cn_name": "留存率", "data_type": "DECIMAL(5,2)", "description": "留存率 = 留存用户数 / 新增用户数，如0.35表示35%留存"}
      ]
    },
    {
      "table_name": "ads_region_rank",
      "table_cn_name": "地区销售排行表",
      "description": "应用层地区销售排行榜，按月统计各省份/城市的销售排名、市场份额。包含GMV排名、订单数排名、市场份额占比。用于区域业绩对比、城市拓展决策、区域资源分配。",
      "datasource": "doris",
      "layer": "ADS",
      "keywords": ["地区排行", "省份排名", "城市排名", "区域销售", "市场份额", "region rank", "地区业绩"],
      "fields": [
        {"field_name": "stat_date", "field_cn_name": "统计日期", "data_type": "DATE", "description": "统计日期"},
        {"field_name": "province_id", "field_cn_name": "省份ID", "data_type": "INT", "description": "省份ID"},
        {"field_name": "province_name", "field_cn_name": "省份名称", "data_type": "VARCHAR(50)", "description": "省份名称，如'广东省'、'北京市'"},
        {"field_name": "gmv", "field_cn_name": "GMV", "data_type": "DECIMAL(18,2)", "description": "该地区GMV"},
        {"field_name": "order_count", "field_cn_name": "订单数", "data_type": "BIGINT", "description": "该地区订单数"},
